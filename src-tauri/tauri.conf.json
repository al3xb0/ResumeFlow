{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ResumeFlow",
  "version": "0.2.0",
  "identifier": "com.sunos.resumeflow",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ResumeFlow — ATS Optimizer",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "shortDescription": "Privacy-first ATS resume optimizer",
    "longDescription": "ResumeFlow analyzes your resume against job descriptions, showing keyword matches and gaps. All processing runs locally — no data leaves your machine.",
    "category": "Utility",
    "copyright": "© 2025 ResumeFlow Contributors",
    "license": "MIT"
  }
}
